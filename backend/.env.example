# 后端环境变量配置

# 服务器端口
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=supercomputing
DB_USER=postgres
DB_PASSWORD=your_password

# JWT密钥
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# 外部系统集成
# 济南超算Grafana
JINAN_GRAFANA_URL=https://grafana.review.dev.supercomputing.link

# 国家超算互联网
SCNET_URL=https://www.scnet.cn

# 中科院网络中心函数服务
CAS_FUNCTION_API_URL=https://api.cas.function.service

# 开发环境
NODE_ENV=development
